// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output          = "../src/generated/prisma"
  moduleFormat  = "cjs"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Gender {
  MALE
  FEMALE
  PREFER_NOT_TO_SAY
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id              Int   @id @default(autoincrement())
  email           String   @unique
  fullName        String
  password        String?  // nullable — Google-OAuth users have no password
  googleId        String?  @unique
  isEmailVerified Boolean  @default(false)
  isPhoneVerified Boolean  @default(false)
  phoneNumber     String?
  countryCode     String?  // e.g. "+1"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // ─── Onboarding profile fields ────────────────────────────────────────────
  displayName           String?
  bio                   String?
  gender                Gender?
  genderVisible         Boolean   @default(true)
  avatarId              String?   // e.g. "male_01" or "female_07"
  interests             String[]  @default([])
  locationGranted       Boolean   @default(false)
  latitude              Float?
  longitude             Float?
  locationArea          String?   // reverse-geocoded area name e.g. "Bandra West"
  username              String?   @unique
  occupation            String?   // e.g. "UX Designer"
  languages             String[]  @default([])  // e.g. ["English", "Hindi"]
  onboardingStep        Int       @default(0)  // last completed step (0 = not started)
  isOnboardingComplete  Boolean   @default(false)

  otpCodes                OtpCode[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]

  // ─── Social relations ─────────────────────────────────────────────────────
  sentRequests     ConnectionRequest[] @relation("SentRequests")
  receivedRequests ConnectionRequest[] @relation("ReceivedRequests")
  blockedByMe      Block[]             @relation("Blocker")
  blockedMe        Block[]             @relation("Blocked")

  @@map("users")
}

// ─── OTP (Phone Verification) ────────────────────────────────────────────────

model OtpCode {
  id          Int   @id @default(autoincrement())
  userId      Int
  phone       String   // full phone with country code, e.g. "+15550001234"
  code        String
  attempts    Int      @default(0)  // wrong-attempt counter; locked at MAX_OTP_ATTEMPTS
  resendCount Int      @default(0)  // resend counter for this OTP session
  expiresAt   DateTime
  isUsed      Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otp_codes")
}

// ─── Email Verification ───────────────────────────────────────────────────────

model EmailVerificationToken {
  id        Int   @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

// ─── Password Reset ───────────────────────────────────────────────────────────

model PasswordResetToken {
  id        Int   @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// ─── Connection Requests ──────────────────────────────────────────────────────

model ConnectionRequest {
  id         Int              @id @default(autoincrement())
  senderId   Int
  receiverId Int
  status     ConnectionStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  sender   User @relation("SentRequests",   fields: [senderId],   references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@map("connection_requests")
}

// ─── Blocks ───────────────────────────────────────────────────────────────────

model Block {
  id        Int      @id @default(autoincrement())
  blockerId Int
  blockedId Int
  createdAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@map("blocks")
}
