# ─── Application ──────────────────────────────────────────────────────────────
PORT=3000

# URL of your frontend app (used for email links and Google OAuth redirect)
FRONTEND_URL=http://localhost:5173

# ─── Database ─────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string
# Pooler URL  → use for normal app queries
# Direct URL  → use for Prisma migrations (prisma migrate dev)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_replace_this_in_production

# Token lifetime — "365d" means 1 year (effectively non-expiring for this app)
# Accepts any value supported by the jsonwebtoken library: "7d", "30d", "365d", "1y"
JWT_EXPIRES_IN=365d

# ─── Email — Resend (resend.com) ──────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Must match a verified domain/sender in your Resend account
MAIL_FROM=NearConnect <noreply@yourdomain.com>

# ─── SMS — Twilio ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15550000000

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs must include GOOGLE_CALLBACK_URL below
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback
